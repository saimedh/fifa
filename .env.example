# Stadium Copilot — Environment Variables

# Base URL of the backend API (no trailing slash)
# Example for local development:
VITE_API_BASE=http://localhost:8000

# ── Backend Configuration ───────────────────────────────────────────────────────
ENVIRONMENT=development

# PostgreSQL Connection String (Relational data)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fifa_genai

# MongoDB Connection String (NoSQL unstructured data)
MONGODB_URL=mongodb://localhost:27017

# Redis Connection String (Caching & Queues)
REDIS_URL=redis://localhost:6379

# ── Tinyfish API ────────────────────────────────────────────────────────────────
# Get your key at https://agent.tinyfish.ai/api-keys
# Used for: Search API (live web search) and Fetch API (page-to-Markdown).
# Leave blank to disable Tinyfish features — the app still works without it.
VITE_TINYFISH_API_KEY=
